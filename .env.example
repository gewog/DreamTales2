# PostgreSQL connection string (required for API and database scripts)
DATABASE_URL=postgresql://user:password@localhost:5432/dreamtales2

# API server port (required)
PORT=8080

# Frontend base path (required for Vite build/dev)
BASE_PATH=/

# Secret key for admin mutations (POST/PUT/DELETE /api/tales).
# Generate a long random string. Required to use the admin panel.
ADMIN_API_KEY=change-me-to-a-long-random-secret

# Optional: restrict CORS to your frontend origin (comma-separated).
# Leave empty to allow all origins (convenient for local dev).
# CORS_ORIGIN=http://localhost:5173
